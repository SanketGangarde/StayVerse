<% layout("/layouts/boilerplate") %>

<div class="row mt-3">

    <div class="col-6 offset-3 mt-3"> 

           <form action="/forgot-password" method="POST" novalidate class="needs-validation">

                <h2 class="mb-3"> Forgot Password</h2>

                <div class="mb-3">

                    <label for="email" class="form-label">Email</label>
                    <input type="email" name="email"  placeholder="enter your registered email" class="form-control" id="email" required >   

                    <button type="submit" class="btn btn-dark mt-3 col-12">send otp</button>

                </div>

            </form>  


                
                    <br>

    </div>

    

</div>    