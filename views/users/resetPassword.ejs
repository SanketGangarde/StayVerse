<% layout("/layouts/boilerplate") %>

<div class="row mt-3">

    <div class="col-6 offset-3 mt-3"> 

           <form action="/reset/<%= token %>" method="POST" novalidate class="needs-validation">

                <h2 class="mb-3"> Reset Password</h2>

                <div class="mb-3">

                    

                    <label for="password" class="form-label ">Password</label>
                    <input type="password" name="password" placeholder="enter new password" class="form-control" id="password" required >   
                    
                    <label for="confirmPassword" class="form-label ">Confirm Password</label>
                    <input type="password" name="confirmPassword" placeholder="Confirm Password" id="confirmPassword" class="form-control"required>

                    <button type="submit" class="btn btn-dark mt-3 col-12">update</button>

                </div>

            </form>  


             
      
                   

                    <br>

    </div>

    

</div>    