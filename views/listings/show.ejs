<script>
// ────────────────────────────────────────────────
const card = document.getElementById('payCard');
const backdrop = document.getElementById('payBackdrop');

if (!card || !backdrop) {
  console.warn("payCard or payBackdrop element not found");
}

// ─── Swipe to close (touch) ───────────────────────
let touchStartY = 0;
let touchCurrentY = 0;

function handleTouchStart(e) {
  touchStartY = e.touches[0].clientY;
}

function handleTouchMove(e) {
  touchCurrentY = e.touches[0].clientY;
  const diff = touchCurrentY - touchStartY;

  // Only allow dragging down when expanded
  if (diff > 0 && card.classList.contains('expanded')) {
    card.style.transform = `translateY(${Math.min(diff, 180)}px)`;
    card.style.transition = 'none'; // smooth following
  }
}

function handleTouchEnd(e) {
  const diff = touchCurrentY - touchStartY;

  card.style.transition = 'transform 0.4s cubic-bezier(0.22, 1, 0.36, 1)';

  if (diff > 80 && card.classList.contains('expanded')) {
    // Collapse on swipe down
    collapseCard();
  } else {
    // Snap back
    card.style.transform = '';
  }
}

// ─── Click to expand when collapsed ───────────────
card.addEventListener('click', (e) => {
  // Prevent this from firing when clicking inside expanded card
  if (card.classList.contains('collapsed')) {
    e.stopPropagation(); // important
    expandCard();
  }
});

// ─── Click outside (backdrop) to close ────────────
backdrop.addEventListener('click', (e) => {
  // Make sure click is directly on backdrop (not bubbled from card)
  if (e.target === backdrop && card.classList.contains('expanded')) {
    collapseCard();
  }
});

// Also support clicking anywhere outside card (more reliable on mobile)
document.addEventListener('click', (e) => {
  if (card.classList.contains('expanded')) {
    // If click is NOT inside the card → close
    if (!card.contains(e.target)) {
      collapseCard();
    }
  }
});

// ─── Helper functions ─────────────────────────────
function expandCard() {
  card.classList.remove('collapsed');
  card.classList.add('expanded');
  backdrop.classList.add('show');
  card.style.transform = ''; // reset any drag
}

function collapseCard() {
  card.classList.remove('expanded');
  card.classList.add('collapsed');
  backdrop.classList.remove('show');
  card.style.transform = '';
}

// ─── Attach touch listeners only once ───────────
card.addEventListener('touchstart', handleTouchStart, { passive: true });
card.addEventListener('touchmove', handleTouchMove, { passive: false });
card.addEventListener('touchend', handleTouchEnd, { passive: true });

// Optional: close on ESC key (desktop testing)
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && card.classList.contains('expanded')) {
    collapseCard();
  }
});
</script>



<!-- --------------------------bookinng form ---------------------- -->
<script>
  const form = document.getElementById("bookingForm");

  form.addEventListener("submit", function (e) {
    e.preventDefault();

    const checkinInput = form.querySelector("#checkin");
    const checkoutInput = form.querySelector("#checkout");
    const guestsInput = form.querySelector("#guests");

    const checkin = checkinInput?.value;
    const checkout = checkoutInput?.value;
    const guestCount = guestsInput?.value || 1;

    if (!checkin || !checkout) {
      alert("Please select check-in and check-out dates");
      return;
    }

    // Convert to Date objects (important)
    const checkinDate = new Date(checkin);
    const checkoutDate = new Date(checkout);

    checkinDate.setHours(0, 0, 0, 0);
    checkoutDate.setHours(0, 0, 0, 0);

    const MS_PER_DAY = 1000 * 60 * 60 * 24;
    const nightCount = (checkoutDate - checkinDate) / MS_PER_DAY;

    if (nightCount < 1) {
      alert("Minimum stay is 1 night (checkout must be after check-in)");
      return;
    }

    //  Store booking data (night-based logic)
    const data = {
      checkin,
      checkout,
      guestCount,
      nights: nightCount
    };

    document.cookie = `searchData=${encodeURIComponent(
      JSON.stringify(data)
    )}; path=/; max-age=86400`;

    // Redirect to booking page
    window.location.href = "/listings/<%= listing._id %>/book";
  });
</script>



<!-- ----------------------- checkout --------------------------- -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
// Function to refresh blocked dates after booking
function refreshBlockedDates() {
  // Reload the page to fetch updated bookings
  location.reload();
}

document.addEventListener("DOMContentLoaded", () => {
  const form = document.getElementById("bookingForm");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const checkin = form.checkin.value;
    const checkout = form.checkout.value;
    const guestCount = form.guests.value;

    if (!checkin || !checkout || !guestCount) {
      alert("Fill all fields");
      return;
    }

    const inDate = new Date(checkin);
    const outDate = new Date(checkout);
    const nights = (outDate - inDate) / (1000 * 60 * 60 * 24);

    if (nights < 1) {
      alert("Checkout must be after check-in");
      return;
    }

    // Store booking data in cookie (so backend can read it)
    document.cookie = `searchData=${encodeURIComponent(
      JSON.stringify({ checkin, checkout, guestCount, nights })
    )}; path=/; max-age=86400`;

    const listingId = "<%= listing._id %>";

    //  Call backend to create Razorpay order
    const res = await fetch(`/listings/${listingId}/book`, {
      method: "GET",
      credentials: "include"
    });
    const data = await res.json();

    if (!data.orderId) {
      return alert("Order creation failed");
    }

    //  Open Razorpay popup
    const rzp = new Razorpay({
      key: data.razorpayKey,
      amount: data.amount,
      currency: data.currency,
      name: "Stay Booking",
      description: `${data.nights} night stay`,
      order_id: data.orderId,
      handler: async (response) => {
        //  Verify payment
        const verifyRes = await fetch(`/listings/${listingId}/book/verify-payment`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ ...response, listingId })
        });
        const result = await verifyRes.json();

        //  Redirect to success page if payment verified
        if (result.success) {
          // If redirecting back to listing, refresh blocked dates
          if (result.redirectUrl && result.redirectUrl.includes('/listings/')) {
            window.location.href = result.redirectUrl;
          } else {
            window.location.href = "/bookings/success";
          }
        } else {
          alert("Payment verification failed");
        }
      },
      theme: { color: "#dc3545" }
    });

    rzp.open();
  });
});
</script>
