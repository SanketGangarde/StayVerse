<script>
  const blockedDates = <%- JSON.stringify(blockedDates || []) %>;

  // Initialize flatpickr for checkout field
  const checkoutPicker = flatpickr("#checkout", {
    dateFormat: "Y-m-d",
    minDate: "today",
    disable: blockedDates,
    clickOpens: true, // Allow clicking to open
    allowInput: true, // Allow manual input
    altInput: true,   // Show readable format
    altFormat: "F j, Y"
  });

  // Initialize flatpickr for checkin field
  const checkinPicker = flatpickr("#checkin", {
    dateFormat: "Y-m-d",
    minDate: "today",
    disable: blockedDates,
    clickOpens: true, // Allow clicking to open
    allowInput: true, // Allow manual input
    altInput: true,   // Show readable format
    altFormat: "F j, Y",
    onChange(selectedDates) {
      if (!selectedDates.length) return;

      const minCheckout = new Date(selectedDates[0]);
      minCheckout.setDate(minCheckout.getDate() + 1);

      checkoutPicker.set("minDate", minCheckout);
      checkoutPicker.clear();
      // Don't auto-open checkout, let user click it
    }
  });

  // Add event listener to make checkout field clickable
  document.getElementById('checkout').addEventListener('click', function() {
    if (checkoutPicker) {
      checkoutPicker.open();
    }
  });

  // Add validation to ensure checkout is after checkin
  document.getElementById('checkin').addEventListener('change', function() {
    const checkinValue = this.value;
    const checkoutField = document.getElementById('checkout');
    
    if (checkinValue && checkoutField.value) {
      const checkinDate = new Date(checkinValue);
      const checkoutDate = new Date(checkoutField.value);
      
      if (checkoutDate <= checkinDate) {
        alert("Checkout date must be after check-in date");
        checkoutField.value = '';
      }
    }
  });
</script>




<!-- If you're only using /search to store checkin, checkout, guestCount in a cookie, set the cookie in JS directly, then redirect.  -->
<!-- <script src="/js/show.js"></script> -->
<script>
  const searchForm = document.getElementById("searchForm");

  if (searchForm) {
    searchForm.addEventListener("submit", function (e) {
      e.preventDefault();

      const formData = new FormData(searchForm);
      const checkin = formData.get("checkin");
      const checkout = formData.get("checkout");
      const guestCount = formData.get("guestCount");

      // Convert to actual Date objects
      const checkinDate = new Date(checkin);
      const checkoutDate = new Date(checkout);

      //checkout should not be less than or equal to checkin date
      if (checkoutDate <= checkinDate) {
        alert("error : Checkout date must be greater than check-in date.");
        return; //  Stop form submission
      }

      //  Set cookie 
      const data = { checkin, checkout, guestCount };
      document.cookie = `searchData=${encodeURIComponent(JSON.stringify(data))}; path=/; max-age=86400`;

      // Redirect to booking page
      window.location.href = "/listings/<%= listing._id %>/book";
    });
  }
</script>

<script>
  const searchForm1 = document.querySelector(".search-form");
  const whereInput = document.getElementById("where");
  const searchButton = document.querySelector(".search-button");

  if (searchForm1 && whereInput && searchButton) {
    // Expand when "Where" is focused
    whereInput.addEventListener("focus", () => {
      searchForm1.classList.add("active");
    });

    // Collapse when clicking outside
    document.addEventListener("click", (e) => {
      if (!searchForm1.contains(e.target)) {
        searchForm1.classList.remove("active");
      }
    });

    // Collapse when clicking search button
    searchButton.addEventListener("click", () => {
      searchForm1.classList.remove("active");
    });

    // Collapse after form submit
    searchForm1.addEventListener("submit", () => {
      searchForm1.classList.remove("active");
    });
  }
</script>

