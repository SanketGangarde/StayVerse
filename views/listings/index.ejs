<% layout("/layouts/boilerplate") %>
<body>
    
    <br>
   
     <br>

    
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

        <%   for(let listing of allListings ) {  %> 

            <a href="/listings/<%= listing._id %>" class="listing-link">

               <div class="card col listing-card" >

                    <% if (listing.images && listing.images.length > 0 && listing.images[0] && listing.images[0].url) { %>
                        <img src="<%= listing.images[0].url %>" class="card-img-top " alt="listing_image" style="height: 20rem;">
                    <% } %>


                    <div class="card-img-overlay">abc</div>


                    <div class="card-body">

                        <p class="card-text">
                            <b><%= listing.title %> </b>
                            <br>
                            &#x20b9 <%= listing.price ? listing.price.toLocaleString('en-IN') : "N/A" %>/per day
                        </p>

                    </div>

                </div>  

            </a>
    
        <%   }  %> 

    </div>   
    
    
    
    
        
   





    
    
</body>


