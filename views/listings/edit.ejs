<% layout("/layouts/boilerplate") %>
<body>

    <br>

    

    <div class="row">

        <div class="col offset-2">

            <h2>Edit Your Listing</h2>

                <form enctype="multipart/form-data" method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" >

                
                
                <div class="mb-3 col-md-8">

                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" value="<%= listing.title %>" placeholder="enter title" class="form-control" required>   <!-- here we create listing object name="listing[title]" key value pair, key will be title , and value is input come from title -->
                    <div class="valid-feedback"> Title looks good!</div>
                    <div class="invalid-feedback"> Title not looks good!</div>

                </div>


                <div class="mb-3">

                    <label for="roomNumber" class="form-label ">Room Number</label>
                     <input type="number" name="listing[roomNumber]" value="<%= listing.roomNumber %>" placeholder="enter room number" class="form-control" required >   <!-- here we create listing object name="listing[description]" key value pair, key will be description , and value is input come from description -->  
                    <div class="valid-feedback"> Well done!</div>  
                    <div class="invalid-feedback"> Please enter room number </div>  

                </div>
                
                
                <div class="mb-3 col-md-8">
                    <label for="description" class="form-label ">Description</label>
                    <textarea name="listing[description]" placeholder="enter description" class="form-control" required> <%= listing.description %> </textarea><!-- here we create listing object name="listing[description]" key value pair, key will be description , and value is input come from description -->
                    <div class="valid-feedback"> Well done!</div>  
                    <div class="invalid-feedback"> Please enter short description </div>
                </div>

                
                <!-- <div class="mb-3 col-md-8">

                    <label for="image" class="form-label ">Upload New Image</label>
                    <input type="file" name="listing[image]" value="<%= listing.images[0].url %>" placeholder="enter image URL/LINK" class="form-control" required >
                    required
                    <div class="valid-feedback"> Awesome!</div>  
                    <div class="invalid-feedback"> Please enter valid image link </div>

                </div> -->


                <!-- <div class="mb-3">
                    <label for="images" class="form-label">Upload the Listing Images</label>
                    
                    <div id="image-inputs">
                        <input type="file" name="images" accept="image/*" class="form-control mb-2" onchange="previewSelectedFiles(this)">
                    </div>

                    <button type="button" class="addAnotherImgBtn" onclick="addAnotherImageInput()">Add Another Image</button>
                </div> -->

               <div class="row">

                    <h5>Current Images</h5>

                    <% listing.images.forEach((image, index) => { %>

                        <div class="mb-3">
                            <p>
                            <strong>Image <%= index + 1 %>:</strong>
                            <a href="<%= image.url %>" target="_blank">View</a>
                            </p>

                            <!-- DELETE IMAGE (NEW) -->
                            <div class="mb-2">
                                <input type="checkbox" name="deleteImageIndexes" value="<%= index %>" id="deleteImage<%= index %>">
                                <label for="deleteImage<%= index %>" style="color:red;">Delete this image</label>
                            </div>

                            <label for="replaceImage<%= index %>" class="form-label">Replace this image</label>
                            <input type="file" name="replaceImages" class="form-control" accept="image/*" id="replaceImage<%= index %>">
                        </div>

                    <% }) %>


                    <hr>
                    <h5>Choose new  Images to Upload</h5>

                    <div id="image-inputs">
                            <input type="file" name="images" accept="image/*" class="form-control mb-2" onchange="previewSelectedFiles(this)">
                    </div>

                    <button type="button" class="addAnotherImgBtn" onclick="addAnotherImageInput()">Add Another Image</button>
                 
                </div>

               <br>

                
                <div class="row">

                    <div class="mb-3 col-md-4">

                        <label for="price" class="form-label ">Price</label>
                        <input type="number" name="listing[price]" value="<%= listing.price %>" placeholder="enter price" class="form-control" required>
                        <div class="valid-feedback"> Well done!</div>  
                        <div class="invalid-feedback"> Please enter valid price </div> 

                    </div>

                    <div class="mb-3 col-md-4">
                    
                        <label for="country" class="form-label ">Country</label>
                        <input type="text" name="listing[country]" value="<%= listing.country %>" placeholder="enter country" class="form-control" required>
                        <div class="valid-feedback"> Awesome!</div>  
                        <div class="invalid-feedback"> Please enter country name </div>

                    </div>

                </div>

                <div class="mb-3 col-md-8">
                    
                    <label for="location" class="form-label ">Location</label>
                    <input type="text" name="listing[location]" value="<%= listing.location %>" placeholder="enter location" class="form-control" required>
                    <div class="valid-feedback"> Great!</div>  
                    <div class="invalid-feedback"> Please enter valid location </div> 


                </div>

                
                

                <button type="submit" class="btn btn-dark">Edit</button>


            </form>

            <br>

        </div>

    </div>

    
    
</body>
