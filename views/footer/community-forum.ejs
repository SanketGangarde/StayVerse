<% layout("/layouts/boilerplate") %>

<div class="container my-5" style="max-width:900px;">

    <!-- TITLE -->
    <h2 class="mb-4 text-center">Community Forum</h2>

    <p class="text-center text-muted">
        Connect with other <strong>StayVerse</strong> users. Ask questions, share experiences, and learn together 💬
    </p>

    <hr>

    <!-- POST FORM -->
    <div class="card p-4 mb-4 shadow-sm">
        <h5 class="mb-3">Start a Discussion</h5>

        <form action="/community-forum" method="POST">

            <div class="mb-3">
                <input 
                    type="text" 
                    name="title" 
                    class="form-control" 
                    placeholder="Discussion title"
                    required
                >
            </div>

            <div class="mb-3">
                <textarea 
                    name="content" 
                    class="form-control" 
                    rows="3"
                    placeholder="Write your question or experience..."
                    required
                ></textarea>
            </div>

            <button class="btn btn-dark w-100">
                Post Discussion
            </button>

        </form>
    </div>

    <!-- POSTS -->
    <h5 class="mb-3">Recent Discussions</h5>

    <% if(!posts || posts.length === 0){ %>
        <p class="text-muted">No discussions yet. Be the first to post!</p>
    <% } %>

    <% if(posts){ %>
        <% posts.forEach(post => { %>

            <div class="card mb-3 p-3 shadow-sm">
                <h6 class="fw-bold mb-1"><%= post.title %></h6>

                <p class="text-muted mb-2">
                    <%= post.content %>
                </p>

                <small class="text-secondary">
                    Posted by <%= post.author %> • 
                    <%= new Date(post.createdAt).toDateString() %>
                </small>
            </div>

        <% }) %>
    <% } %>

    <hr>

    <p class="text-center text-muted">
        Join the conversation and help build a strong StayVerse community ❤️
    </p>

</div>