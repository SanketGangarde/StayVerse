<% layout("/layouts/dashboard") %>
<br><br>
<div class="container my-5" style="max-width: 1000px;">

    <!-- TITLE -->
    <div class="text-center mb-4">
        <h2>Responsible Hosting</h2>
        <p class="text-muted">
            Learn how to host responsibly, follow local laws, and create a safe experience for everyone 🌍
        </p>
    </div>

    <hr>

    <!-- INTRO -->
    <div class="mb-5">
        <p class="text-muted">
            At <strong>StayVerse</strong>, we believe in building a trusted community. As a host, it’s your responsibility 
            to ensure your property is safe, legal, and respectful to neighbors and guests.
        </p>
    </div>

    <!-- SECTIONS -->
    <div class="row g-4">

        <!-- Safety -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100">
                <h5>🛡️ Safety First</h5>
                <ul class="text-muted small">
                    <li>Install smoke detectors and fire extinguishers</li>
                    <li>Ensure proper ventilation and lighting</li>
                    <li>Provide emergency contact numbers</li>
                    <li>Maintain secure locks and entry systems</li>
                </ul>
            </div>
        </div>

        <!-- Legal -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100">
                <h5>⚖️ Follow Local Laws</h5>
                <ul class="text-muted small">
                    <li>Check local rental and zoning regulations</li>
                    <li>Register your property if required</li>
                    <li>Pay applicable taxes</li>
                    <li>Respect housing society rules</li>
                </ul>
            </div>
        </div>

        <!-- Respect -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100">
                <h5>🤝 Respect Your Neighbors</h5>
                <ul class="text-muted small">
                    <li>Avoid noise disturbances</li>
                    <li>Limit parties and large gatherings</li>
                    <li>Provide clear house rules</li>
                    <li>Handle complaints promptly</li>
                </ul>
            </div>
        </div>

        <!-- Cleanliness -->
        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100">
                <h5>🧼 Clean & Maintain</h5>
                <ul class="text-muted small">
                    <li>Keep your property clean and hygienic</li>
                    <li>Regularly inspect for damages</li>
                    <li>Provide clean linens and essentials</li>
                    <li>Follow health and safety guidelines</li>
                </ul>
            </div>
        </div>

    </div>

    <hr class="my-5">

    <!-- INSURANCE / LIABILITY -->
    <div class="mb-5">
        <h5>🔐 Insurance & Liability</h5>
        <p class="text-muted">
            Consider getting appropriate insurance coverage to protect your property and guests. 
            StayVerse encourages hosts to review their policies and understand liability responsibilities.
        </p>
    </div>

    <!-- CTA -->
    <div class="text-center p-4 bg-light rounded shadow-sm">
        <h5>Be a Responsible Host</h5>
        <p class="text-muted">
            Hosting responsibly helps build trust and ensures a better experience for everyone.
        </p>
        <a href="/listings/new" class="btn btn-dark">
            Start Hosting
        </a>
    </div>

</div>