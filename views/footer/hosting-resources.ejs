<% layout("/layouts/dashboard") %>
<br><br>
<div class="container my-5" style="max-width: 1000px;">

    <!-- PAGE TITLE -->
    <div class="text-center mb-4">
        <h2>Hosting Resources</h2>
        <p class="text-muted">
            Everything you need to become a successful host on <strong>StayVerse</strong> 🏡
        </p>
    </div>

    <hr>

    <!-- INTRO SECTION -->
    <div class="mb-5">
        <h5>Getting Started</h5>
        <p class="text-muted">
            Learn how to list your property, manage bookings, and provide great guest experiences.
        </p>
    </div>

    <!-- RESOURCE CARDS -->
    <div class="row g-4">

        <!-- Resource 1 -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm p-3">
                <h6 class="fw-bold">📌 How to List Your Property</h6>
                <p class="text-muted small">
                    Step-by-step guide to creating your first listing and attracting guests.
                </p>
                <a href="#" class="btn btn-outline-dark btn-sm">
                    Read More
                </a>
            </div>
        </div>

        <!-- Resource 2 -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm p-3">
                <h6 class="fw-bold">💰 Pricing Tips</h6>
                <p class="text-muted small">
                    Learn how to price your property competitively and maximize earnings.
                </p>
                <a href="#" class="btn btn-outline-dark btn-sm">
                    Read More
                </a>
            </div>
        </div>

        <!-- Resource 3 -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm p-3">
                <h6 class="fw-bold">Cleaning & Maintenance</h6>
                <p class="text-muted small">
                    Best practices to keep your space clean, safe, and guest-ready.
                </p>
                <a href="#" class="btn btn-outline-dark btn-sm">
                    Read More
                </a>
            </div>
        </div>

        <!-- Resource 4 -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm p-3">
                <h6 class="fw-bold">⭐ Guest Experience</h6>
                <p class="text-muted small">
                    Tips to deliver amazing experiences and earn great reviews.
                </p>
                <a href="#" class="btn btn-outline-dark btn-sm">
                    Read More
                </a>
            </div>
        </div>

    </div>

    <hr class="my-5">

    <!-- FAQ SECTION -->
    <div class="mb-5">
        <h5 class="mb-3">Frequently Asked Questions</h5>

        <div class="accordion" id="faqAccordion">

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#faq1">
                        How do I become a host?
                    </button>
                </h2>
                <div id="faq1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        Simply create an account, add your property details, upload images, and publish your listing.
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq2">
                        How do I get paid?
                    </button>
                </h2>
                <div id="faq2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Payments are securely processed and transferred to your registered account after booking confirmation.
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- CTA SECTION -->
    <div class="text-center p-4 bg-light rounded shadow-sm">
        <h5>Ready to start hosting?</h5>
        <p class="text-muted">
            List your property today and start earning with StayVerse ❤️
        </p>
        <a href="/listings/new" class="btn btn-dark">
            Become a Host
        </a>
    </div>

</div>