<% layout("/layouts/dashboard") %>

<br><br>
<div class="container my-5" style="max-width:700px;">

    <h2 class="mb-4">Report an Issue</h2>

    <p>
        Facing a problem with a booking, listing, or user? Let us know and we’ll help you resolve it quickly.
    </p>

    <hr>

    <!-- FORM -->
    <form action="/report-issue" method="POST">

        <!-- NAME -->
        <div class="mb-3">
            <label class="form-label">Your Name</label>
            <input 
                type="text" 
                name="name" 
                class="form-control" 
                placeholder="Enter your name"
                required
            >
        </div>

        <!-- EMAIL -->
        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input 
                type="email" 
                name="email" 
                class="form-control" 
                placeholder="Enter your email"
                required
            >
        </div>

        <!-- ISSUE TYPE -->
        <div class="mb-3">
            <label class="form-label">Issue Type</label>
            <select name="issueType" class="form-select" required>
                <option value="">Select an issue</option>
                <option>Booking Problem</option>
                <option>Payment Issue</option>
                <option>Host/Guest Behavior</option>
                <option>Technical Bug</option>
                <option>Other</option>
            </select>
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-3">
            <label class="form-label">Describe Your Issue</label>
            <textarea 
                name="description" 
                class="form-control" 
                rows="5"
                placeholder="Explain the issue in detail..."
                required
            ></textarea>
        </div>

        <!-- SUBMIT -->
        <button class="btn btn-dark w-100">
            Submit Issue
        </button>

    </form>

    <hr>

    <p class="text-muted">
        Our support team will review your issue and get back to you within 24–48 hours.
    </p>

</div>