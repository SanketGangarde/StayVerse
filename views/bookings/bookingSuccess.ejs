<% layout("/layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="card shadow-lg p-4 text-center" style="max-width: 420px; width: 100%; border-radius: 16px;">
    
    <!-- Success Icon -->
    <div style="font-size: 64px;">✅</div>

    <h3 class="mt-3">Booking Confirmed!</h3>
    <p class="text-muted mt-2">
      Your payment was successful and your stay is confirmed.
    </p>

    <hr>

    <p class="mb-3">
      A confirmation email will be sent shortly.
    </p>

    <a href="/dashboard" class="btn btn-danger w-100 mb-2">
      View My Bookings
    </a>

    <a href="/listings" class="btn btn-outline-secondary w-100">
      Back to Home
    </a>

  </div>
</div>
